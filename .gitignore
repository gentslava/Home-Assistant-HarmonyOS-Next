# Monorepo .gitignore — recursive across apps/*

# Dependencies
**/node_modules/
**/oh_modules/

# Build output / tooling caches
**/build/
**/.hvigor/
**/.cxx/
**/.cache/

# IDE / local config
**/.idea/
**/local.properties
**/.clangd
**/.clang-format
**/.clang-tidy
**/.test/
**/.appanalyzer/

# Signing material — secrets, never commit (keystores, certs, profiles)
**/*.p12
**/*.p7b
**/*.cer
**/*.keystore
**/*.jks

# OS
.DS_Store
